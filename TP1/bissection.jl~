function bissection(g :: Function,
                    I :: Tuple{Float64,Float64};
                    tol :: Real = 1e-8,
                    maxiter :: Int = 50,
                    verbose :: Bool = true)

    verbose &&
        @printf(" iter  I[1]          I[2]         g(t)\n")
    mid = 0.0
    iter = 0
    while ((I[2]-I[1]) > tol)
        mid = (I[1]+I[2])/2.0
        iter += 1

        if g(mid) <= 0.0
            I = (mid, I[2])
        else
            I = (I[1], mid)
        end
        verbose && @printf(" %4d %9.2e  %9.2e  %9.2e\n",
                           iter, I[1], I[2], g(mid))
    end

    return mid
end

