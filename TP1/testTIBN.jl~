# JuMP et NLPModels sont des outils de modélisation.

using JuMP, NLPModels

include("line_model.jl")
include("TrouveInt.jl")
include("bissection.jl")
include("bissection_Newton.jl")


# Exemple de la table 2.3 des notes; la figure 2.8 illustre la fonction
#
# Quelques trucs julia pour ne spécifier le nom du test une seule fois...

name = "Dus2_9"
println(" Exemple avec le test ",name)

symb = Symbol(name)

file = string(name, ".jl")

include(file)
f = getfield(Main, symb)

nlp = MathProgNLPModel(f())

h = LineModel(nlp, [0.0], [1.0])

g(x) = grad(h,x)
H(x) = hess(h,x)

t₀ = 2.0

println(" Trouve_Intervalle : ")
I, iterT = Trouve_intervalle(h, t₀, incδ = 5.0)

println(" Après Trouve_Intervalle, bissection")
xb, iterb = bissection(g,I, tol = 1e-9)
println(" Après Trouve_Intervalle, bissection_Newton")

xbn, iterbn = bissection_Newton(g,H,I, tol = 1e-9)

println("total iter TI et bissection  = ",iterT+iterb)
println("total iter TI et bissectionN = ",iterT+iterbn)
